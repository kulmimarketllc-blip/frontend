# ==================================================
# ENVIRONMENT CONFIGURATION
# ==================================================
# Copy this file to .env and update with your values
# Never commit .env to version control!

# ==================================================
# API Configuration (REQUIRED)
# ==================================================
# Base URL for your backend API
VITE_API_BASE_URL=https://api.example.com

# ==================================================
# Application Configuration (REQUIRED)
# ==================================================
# Name of your application
VITE_APP_NAME=React Boilerplate

# ==================================================
# Optional: Analytics & Monitoring
# ==================================================
# VITE_ANALYTICS_ID=your_analytics_id_here
# VITE_SENTRY_DSN=https://your_sentry_dsn@sentry.io/project

# ==================================================
# Optional: Feature Flags
# ==================================================
# VITE_ENABLE_ANALYTICS=false
# VITE_ENABLE_ERROR_TRACKING=true

# ==================================================
# Optional: Third-party Services
# ==================================================
# Use placeholder values - never real keys!
# VITE_STRIPE_PUBLIC_KEY=pk_test_your_stripe_key_here
# VITE_GOOGLE_MAPS_API_KEY=your_google_maps_key_here

# ==================================================
# ⚠️ SECURITY NOTES
# ==================================================
# 1. Never commit the actual .env file to version control
# 2. Only VITE_ prefixed variables are exposed to the client
# 3. VITE_ variables are PUBLIC in the browser bundle
# 4. Never put sensitive secrets (API keys, passwords) in VITE_ variables
# 5. For sensitive operations, always use backend API calls
# 6. Ensure .env is in .gitignore
# 7. Use different values for development, staging, and production
# ==================================================
